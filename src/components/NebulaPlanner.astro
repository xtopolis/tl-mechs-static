---
// NebulaPlanner: spawn timing and location calculator for Nebula Island events.
---

<div class="np not-content">

  <!-- Controls -->
  <div class="np-panel">

    <div class="np-row">
      <span class="np-row-label">Current time</span>
      <input class="np-time" type="time" id="np-time" />
    </div>

    <div class="np-row">
      <span class="np-row-label">Current spawns</span>
      <div class="np-type-group">
        <button class="np-type-btn" id="np-btn-chest" title="Chests" aria-label="Chests"><span>🎁</span></button>
        <button class="np-type-btn" id="np-btn-stone" title="Stones" aria-label="Stones"><span>🪨</span></button>
      </div>
    </div>

    <div class="np-row">
      <span class="np-row-label">Location</span>
      <div class="np-loc-group" id="np-loc-group">
        <span class="np-loc-btn np-loc-disabled" data-loc="0">Shrine</span>
        <span class="np-loc-btn np-loc-disabled" data-loc="1">Arkeum</span>
        <span class="np-loc-btn np-loc-disabled" data-loc="2">Orc Village</span>
        <span class="np-loc-btn np-loc-disabled" data-loc="3">Seal Sanctuary</span>
      </div>
    </div>

  </div>

  <!-- Validity message -->
  <p id="np-validity-msg" class="np-validity-msg"></p>

  <!-- Output -->
  <div class="np-output" id="np-output">

    <!-- Current Hour: combined timing + location table -->
    <div>
      <p class="np-section-title">Current Hour</p>
      <table class="np-table np-current-table">
        <thead>
          <tr>
            <th>12hr</th>
            <th>24hr</th>
            <th>🎁</th>
            <th>🪨</th>
          </tr>
        </thead>
        <tbody id="np-current-tbody"></tbody>
      </table>
    </div>

    <!-- Forecast: today open, remaining days collapsed -->
    <div id="np-forecast-container"></div>

  </div>

  <script is:inline>
    (() => {
      const ROTATION = ['Shrine', 'Arkeum', 'Orc Village', 'Seal Sanctuary'];
      const LS_KEY = 'nebula-v1';

      const MS_PER_HOUR = 3_600_000;
      const MS_PER_WEEK = 7 * 24 * MS_PER_HOUR;

      function pad(n) { return String(n).padStart(2, '0'); }
      function fmtHour(h24, mins) {
        const h = h24 % 24;
        const suffix = h < 12 ? 'AM' : 'PM';
        const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
        return mins !== undefined
          ? `${h12}:${pad(mins)} ${suffix}`
          : `${h12} ${suffix}`;
      }

      // Server reset = every Thursday 00:00 PDT = Thursday 07:00 UTC
      function getNextReset() {
        const now = new Date();
        const d = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), 7, 0, 0, 0));
        const diff = (4 - d.getUTCDay() + 7) % 7;
        d.setUTCDate(d.getUTCDate() + diff);
        if (d <= now) d.setUTCDate(d.getUTCDate() + 7);
        return d;
      }

      function loadSaved() {
        try {
          const raw = localStorage.getItem(LS_KEY);
          if (!raw) return null;
          const data = JSON.parse(raw);
          if (!data.type || data.loc == null || !data.timestamp) return null;
          if (data.timestamp < getNextReset().getTime() - MS_PER_WEEK) return null;
          return data;
        } catch { return null; }
      }

      function saveCurrent(type, loc) {
        try {
          localStorage.setItem(LS_KEY, JSON.stringify({ type, loc, timestamp: Date.now() }));
        } catch {}
      }

      function buildDayTable(rows) {
        return `<table class="np-table">
          <thead><tr>
            <th class="np-col-hour">12hr</th>
            <th class="np-col-hour">24hr</th>
            <th>🎁</th>
            <th>🪨</th>
          </tr></thead>
          <tbody>${rows.join('')}</tbody>
        </table>`;
      }

      let selectedType = null;
      let selectedLoc  = null;

      const timeInput         = document.getElementById('np-time');
      const btnChest          = document.getElementById('np-btn-chest');
      const btnStone          = document.getElementById('np-btn-stone');
      const locBtns           = document.querySelectorAll('#np-loc-group .np-loc-btn');
      const output            = document.getElementById('np-output');
      const currentTbody      = document.getElementById('np-current-tbody');
      const forecastContainer = document.getElementById('np-forecast-container');
      const validityMsg       = document.getElementById('np-validity-msg');

      const now = new Date();
      timeInput.value = pad(now.getHours()) + ':' + pad(now.getMinutes());

      function setType(type) {
        selectedType = type;
        btnChest.classList.toggle('np-active', type === 'chest');
        btnStone.classList.toggle('np-active', type === 'stone');
        locBtns.forEach(b => b.classList.remove('np-loc-disabled'));
        tryCalculate();
      }

      function setLoc(loc) {
        const btn = document.querySelector(`#np-loc-group .np-loc-btn[data-loc="${loc}"]`);
        if (!btn) return;
        locBtns.forEach(b => b.classList.remove('np-active'));
        btn.classList.add('np-active');
        selectedLoc = loc;
        tryCalculate();
      }

      btnChest.addEventListener('click', () => setType('chest'));
      btnStone.addEventListener('click', () => setType('stone'));

      locBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('np-loc-disabled')) return;
          setLoc(parseInt(btn.dataset.loc, 10));
        });
      });

      timeInput.addEventListener('change', tryCalculate);
      timeInput.addEventListener('input', tryCalculate);

      function tryCalculate() {
        if (selectedType === null || selectedLoc === null) return;
        const val = timeInput.value;
        if (!val) return;
        const [hStr, mStr] = val.split(':');
        const h = parseInt(hStr, 10);
        const m = parseInt(mStr, 10);
        if (isNaN(h) || isNaN(m)) return;

        const chestIdx = selectedType === 'chest' ? selectedLoc : (selectedLoc + 3) % 4;
        const stoneIdx = (chestIdx + 1) % 4;

        saveCurrent(selectedType, selectedLoc);

        currentTbody.innerHTML = [0, 20, 40].map(sm => {
          const stale = (m - sm) > 5;
          return `<tr class="${stale ? 'np-timing-stale' : ''}">
            <td>${fmtHour(h, sm)}</td>
            <td>${pad(h)}:${pad(sm)}</td>
            <td>${ROTATION[chestIdx]}</td>
            <td>${ROTATION[stoneIdx]}</td>
          </tr>`;
        }).join('');

        const nextReset = getNextReset();
        buildForecast(chestIdx, h, nextReset);
        updateValidityMsg(nextReset);
        output.classList.add('np-visible');
      }

      function buildForecast(chestIdx, currentHour, nextReset) {
        const now = new Date();
        const baseDate = new Date(now);
        baseDate.setHours(currentHour, 0, 0, 0);

        const dayMap = new Map();
        const todayKey = now.toDateString();

        for (let i = 1; ; i++) {
          const fd = new Date(baseDate.getTime() + i * MS_PER_HOUR);
          if (fd >= nextReset) break;
          if (fd <= now) continue;

          const fChestIdx = (chestIdx + i) % 4;
          const fStoneIdx = (fChestIdx + 1) % 4;
          const dateKey   = fd.toDateString();

          let entry = dayMap.get(dateKey);
          if (!entry) {
            const label = dateKey === todayKey
              ? 'Today'
              : fd.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
            entry = { label, isToday: dateKey === todayKey, rows: [] };
            dayMap.set(dateKey, entry);
          }

          const h24 = fd.getHours();
          entry.rows.push(`<tr>
            <td class="np-col-hour"><strong>${fmtHour(h24)}</strong></td>
            <td class="np-col-hour">${pad(h24)}:00</td>
            <td>${ROTATION[fChestIdx]}</td>
            <td>${ROTATION[fStoneIdx]}</td>
          </tr>`);
        }

        forecastContainer.innerHTML = '';

        if (dayMap.size === 0) {
          forecastContainer.innerHTML = '<p class="np-validity-msg">Reset is approaching — no remaining forecast hours.</p>';
          return;
        }

        [...dayMap.values()].forEach((day, idx) => {
          if (day.isToday) {
            const div = document.createElement('div');
            div.innerHTML = `<p class="np-section-title">Today</p>${buildDayTable(day.rows)}`;
            forecastContainer.appendChild(div);
          } else {
            const details = document.createElement('details');
            details.className = 'np-forecast-details';
            if (idx === 0) details.open = true;
            details.innerHTML = `<summary class="np-forecast-summary">${day.label}</summary>${buildDayTable(day.rows)}`;
            forecastContainer.appendChild(details);
          }
        });
      }

      function updateValidityMsg(nextReset) {
        if (!nextReset) {
          validityMsg.textContent = '';
          return;
        }
        const msLeft    = nextReset.getTime() - Date.now();
        const hoursLeft = Math.floor(msLeft / MS_PER_HOUR);
        const daysLeft  = Math.floor(hoursLeft / 24);
        validityMsg.textContent = daysLeft >= 1
          ? `Forecast valid for ${daysLeft} day${daysLeft !== 1 ? 's' : ''}`
          : `Forecast valid for ${hoursLeft} hour${hoursLeft !== 1 ? 's' : ''}`;
      }

      // Restore saved state on load
      const saved = loadSaved();
      if (saved) {
        setType(saved.type);
        setLoc(saved.loc);
      }
    })();
  </script>

</div>

<style is:global>
  .np {
    margin-top: 1em;
  }

  /* ── Controls panel ── */
  .np-panel {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 10px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 12px;
  }

  .np-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .np-row-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--sl-color-gray-2);
    white-space: nowrap;
    min-width: 130px;
  }

  /* Time input */
  .np-time {
    padding: 6px 10px;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 6px;
    background: var(--sl-color-gray-7);
    color: var(--sl-color-text);
    font-size: 15px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  /* ── Type emoji buttons ── */
  .np-type-group {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .np-type-btn {
    width: 44px;
    height: 44px;
    padding: 0;
    border: 2px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-gray-7);
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s, background 0.15s;
  }
  .np-type-btn span {
    font-size: 22px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    user-select: none;
  }
  .np-type-btn:hover {
    border-color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
  }
  .np-type-btn.np-active {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
  }

  /* ── Location radio pills ── */
  .np-loc-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }

  .np-loc-btn {
    padding: 6px 14px;
    border: 2px solid var(--sl-color-gray-5);
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    color: var(--sl-color-text);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, opacity 0.15s;
    user-select: none;
    line-height: 1.4;
  }
  .np-loc-btn.np-loc-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }
  .np-loc-btn:hover:not(.np-loc-disabled) {
    border-color: var(--sl-color-gray-3);
    background: var(--sl-color-gray-6);
  }
  .np-loc-btn.np-active {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
    font-weight: 700;
  }

  /* ── Validity message ── */
  .np-validity-msg {
    font-size: 12px;
    color: var(--sl-color-gray-3);
    margin: 0 0 16px;
    min-height: 1em;
  }

  /* ── Output ── */
  .np-output {
    display: none;
    flex-direction: column;
    gap: 20px;
  }
  .np-output.np-visible {
    display: flex;
  }

  /* ── Current hour table ── */
  .np-current-table {
    max-width: 420px;
  }
  .np-timing-stale td {
    opacity: 0.35;
  }

  /* ── Section titles ── */
  .np-section-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
    margin: 0 0 10px;
  }

  /* ── Tables ── */
  .np-table {
    border-collapse: collapse;
    width: 100%;
    max-width: 480px;
    font-size: 14px;
  }
  .np-table th,
  .np-table td {
    padding: 8px 16px;
    border-bottom: 1px solid var(--sl-color-gray-6);
    color: var(--sl-color-text);
    text-align: left;
  }
  .np-table th:first-child,
  .np-table td:first-child {
    padding-left: 12px;
  }
  .np-table th:last-child,
  .np-table td:last-child {
    padding-right: 12px;
  }
  .np-table thead th {
    background: var(--sl-color-gray-6);
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--sl-color-gray-5);
  }
  .np-table tbody tr:last-child td {
    border-bottom: none;
  }
  .np-col-hour {
    text-align: center !important;
  }
  .np-table thead th:nth-child(n+3),
  .np-table tbody td:nth-child(n+3) {
    text-align: center;
  }

  /* ── Forecast day sections ── */
  .np-forecast-details {
    max-width: 480px;
  }
  .np-forecast-summary {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    padding: 6px 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
    user-select: none;
  }
  .np-forecast-summary::-webkit-details-marker { display: none; }
  .np-forecast-summary::before {
    content: '›';
    font-size: 16px;
    line-height: 1;
    transition: transform 0.15s;
    display: inline-block;
  }
  .np-forecast-details[open] > .np-forecast-summary::before {
    transform: rotate(90deg);
  }
  .np-forecast-details > .np-table {
    margin-top: 8px;
  }
</style>
